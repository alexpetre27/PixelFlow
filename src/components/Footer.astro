---
import { ui } from '@/i18n/ui';

const { lang = 'ro' } = Astro.props;
const t = ui[lang as keyof typeof ui];
const currentYear = new Date().getFullYear();
---

<footer class="relative w-full overflow-hidden bg-linear-to-b from-[#03060d] to-black">
  <div class="mx-auto flex w-full max-w-7xl flex-col gap-8 px-6 py-12 md:py-14">
    <div class="grid gap-8 md:grid-cols-12 md:items-start">
      <div class="md:col-span-5">
    <a href=/#home class="flex items-center gap-3 pl-4 shrink-0">
  <img 
    src="/logonobg.png" 
    alt="StackStory Logo" 
    class="w-8 h-8 object-contain" 
    width="48" 
    height="48"
  />
  <span class="text-white font-black tracking-tighter text-sm hidden sm:block">STACKSTORY</span>
</a>
        <p class="mt-4 max-w-md text-sm leading-relaxed text-white/65">
          {t['footer.desc']}
        </p>
      </div>

      <div class="md:col-span-3">
        <p class="text-[11px] font-bold uppercase tracking-[0.16em] text-zinc-500">{t['footer.nav']}</p>
        <div class="mt-4 flex flex-col gap-2 text-sm">
          <a href="/#home" class="text-zinc-300 transition-colors hover:text-amber-200">{t['footer.nav.home']}</a>
          <a href="/#services" class="text-zinc-300 transition-colors hover:text-amber-200">{t['footer.nav.services']}</a>
          <a href="/#work" class="text-zinc-300 transition-colors hover:text-amber-200">{t['footer.nav.work']}</a>
          <a href="/#testimonials" class="text-zinc-300 transition-colors hover:text-amber-200">{t['footer.nav.test']}</a>
          <a href="/#contact" class="text-zinc-300 transition-colors hover:text-amber-200">{t['footer.nav.contact']}</a>
        </div>
      </div>

      <div class="md:col-span-4">
        <p class="text-[11px] font-bold uppercase tracking-[0.16em] text-zinc-500">{t['footer.company']}</p>
        <div class="mt-4 space-y-2 text-sm text-zinc-300">
          <p>StackStory SRL</p>
          <a href="mailto:stackstory.contact@gmail.com" class="block transition-colors hover:text-amber-200">stackstory.contact@gmail.com</a>
          <a href="tel:+40784360067" class="block transition-colors hover:text-amber-200">+40 784 360 067</a>
        </div>
      </div>
    </div>

    {lang === 'ro' && (
      <div class="grid gap-6 rounded-2xl border border-white/10 bg-white/2 p-4 md:grid-cols-12 md:items-center">
        <div class="md:col-span-6">
          <p class="text-[11px] font-bold uppercase tracking-[0.16em] text-zinc-500">{t['footer.legal.compliance']}</p>
        </div>
        <div class="flex flex-col gap-2 sm:flex-row sm:items-center md:col-span-6 md:justify-end">
          <a
            href="https://anpc.ro/sal/"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex w-full overflow-hidden rounded-xl border border-white/15 transition-colors hover:border-amber-200/50 sm:w-52.5"
            aria-label="Soluționarea Alternativă a Litigiilor - ANPC"
          >
            <img src="https://anpc.ro/wp-content/uploads/2022/07/SAL-PICTOGRAMA.png" alt="ANPC SAL" class="h-10.5 w-full object-cover" loading="lazy" />
          </a>
          <a
            href="https://anpc.ro/wp-content/uploads/2022/08/pictogramaSOL.png"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex w-full overflow-hidden rounded-xl border border-white/15 transition-colors hover:border-amber-200/50 sm:w-52.5"
            aria-label="Soluționarea Online a Litigiilor"
          >
            <img src="https://anpc.ro/wp-content/uploads/2022/08/pictogramaSOL.png" alt="ANPC SOL" class="h-10.5 w-full object-cover" loading="lazy" />
          </a>
        </div>
      </div>
    )}

    <div class="flex flex-wrap items-center gap-x-4 gap-y-2 text-xs text-zinc-400">
      <a href="/termeni-si-conditii" class="transition-colors hover:text-amber-200">{t['footer.legal.terms']}</a>
      <a href="/politica-de-confidentialitate" class="transition-colors hover:text-amber-200">{t['footer.legal.privacy']}</a>
      <a href="/politica-de-cookies" class="transition-colors hover:text-amber-200">{t['footer.legal.cookies']}</a>
    </div>

    <div class="h-px w-full bg-white/10"></div>

    <div class="flex flex-col gap-2 text-xs text-zinc-500 sm:flex-row sm:items-center sm:justify-between">
      <p>© {currentYear} StackStory. {t['footer.rights']}</p>
    </div>
  </div>
</footer>