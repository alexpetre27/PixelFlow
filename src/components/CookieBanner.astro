---
import { ui } from '@/i18n/ui';

const { lang = 'ro' } = Astro.props;
const t = ui[lang as keyof typeof ui];
---

<div 
  id="cookie-banner" 
  class="fixed bottom-6 left-6 z-[9999] w-[calc(100%-3rem)] max-w-[380px] translate-y-[150%] opacity-0 transition-all duration-700 ease-[cubic-bezier(0.22,1,0.36,1)] rounded-3xl border border-white/10 bg-[#03060d]/85 p-6 shadow-[0_20px_50px_rgba(0,0,0,0.8)] backdrop-blur-2xl pointer-events-auto"
  aria-hidden="true"
>
  <div class="flex items-center gap-3 mb-3">
    <div class="flex h-9 w-9 items-center justify-center rounded-full bg-amber-200/10 text-amber-200">
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2a10 10 0 1 0 10 10 4 4 0 0 1-5-5 4 4 0 0 1-5-5"/><path d="M8.5 8.5v.01"/><path d="M16 12.5v.01"/><path d="M12 16v.01"/><path d="M11 11v.01"/><path d="M16 17v.01"/></svg>
    </div>
    <h3 class="text-sm font-bold tracking-wide text-white">{t['cookie.title']}</h3>
  </div>
  
  <p class="mb-5 text-xs leading-relaxed text-white/65">
    {t['cookie.desc']}
  </p>
  
  <div class="flex flex-col gap-2 sm:flex-row">
    <button 
      id="accept-cookies" 
      class="flex-1 rounded-xl border border-amber-200/35 bg-amber-200/10 px-4 py-2.5 text-[10px] font-bold uppercase tracking-[0.14em] text-amber-100 transition-all hover:bg-amber-200/20 hover:border-amber-200/55"
    >
      {t['cookie.accept']}
    </button>
    <button 
      id="reject-cookies" 
      class="flex-1 rounded-xl border border-white/10 bg-transparent px-4 py-2.5 text-[10px] font-bold uppercase tracking-[0.14em] text-zinc-400 transition-all hover:bg-white/5 hover:text-white"
    >
      {t['cookie.reject']}
    </button>
  </div>
</div>

<script>
  const initCookieBanner = () => {
    const banner = document.getElementById('cookie-banner');
    const btnAccept = document.getElementById('accept-cookies');
    const btnReject = document.getElementById('reject-cookies');

    if (!banner || !btnAccept || !btnReject) return;

    const hasConsented = localStorage.getItem('cookieConsent');

    if (!hasConsented) {
      setTimeout(() => {
        banner.classList.remove('translate-y-[150%]', 'opacity-0');
        banner.removeAttribute('aria-hidden');
      }, 1200);
    }

    const closeBanner = (status: string) => {
      localStorage.setItem('cookieConsent', status);
      
      banner.classList.add('translate-y-[150%]', 'opacity-0');
      setTimeout(() => {
        banner.setAttribute('aria-hidden', 'true');
        banner.style.display = 'none';
      }, 700);
    };

    btnAccept.addEventListener('click', () => closeBanner('accepted'));
    btnReject.addEventListener('click', () => closeBanner('essentials'));
  };

  initCookieBanner();
  document.addEventListener("astro:after-swap", initCookieBanner);
</script>