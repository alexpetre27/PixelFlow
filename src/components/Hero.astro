---
import { MoveRight } from "lucide-react";

const { backgroundImage = "/ffff.jpg" } = Astro.props;
---

<section class="relative min-h-screen w-full overflow-hidden" id="home">
  <div
    class="absolute inset-0 z-0 bg-cover bg-center bg-no-repeat bg-fixed"
    style={`background-image: url(${backgroundImage});`}
  >
    <div class="absolute inset-0 bg-black/50"></div>
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_50%_42%,rgba(255,200,120,0.16),transparent_62%)]"></div>
    <div class="absolute inset-0 shadow-[inset_0_0_220px_rgba(3,6,13,0.92)]"></div>
  </div>

  <div class="relative z-10 mx-auto flex min-h-screen max-w-5xl flex-col items-center justify-center px-6 text-center pt-32 md:pt-40">
    <div class="mb-8">
      <div class="inline-block px-8 py-3 rounded-2xl 
                  bg-black/40 border border-white/10 
                  backdrop-blur-l
                  shadow-[0_20px_60px_rgba(0,0,0,0.6)]">
        <p class="text-[11px] uppercase tracking-[0.4em] font-bold text-white/85">
          STRATEGIE • DESIGN • CONVERSIE
        </p>
      </div>
    </div>
    <h1 class="max-w-4xl text-balance font-semibold leading-[1.06] tracking-[-0.03em] text-white [font-family:ui-sans-serif,system-ui,-apple-system,Segoe_UI,Inter,Helvetica,Arial] text-[36px] md:text-[70px]">
      Ai trafic.
      <span class="block mt-2 text-white/90">
        Dar câți se opresc să{" "}
        <span class="relative inline-block">
          <span class="text-amber-200/95">cumpere?</span>
          <span class="absolute -bottom-2 left-0 h-px w-full bg-gradient-to-r from-transparent via-amber-200/70 to-transparent"></span>
        </span>
      </span>
    </h1>

    <p class="mt-10 max-w-2xl text-pretty text-white/70 text-[17px] md:text-[19px] leading-relaxed font-[ui-sans-serif,system-ui,-apple-system,Segoe_UI,Inter,Helvetica,Arial]">
      <span class="block mb-5 text-[20px] md:text-[22px] font-medium text-amber-100/90">
        Transformăm traficul anonim în clienți reali.
      </span>
      Mii de oameni trec zilnic pe lângă afacerea ta online. Construim experiențe care îi fac să se oprească, să înțeleagă și să acționeze.
    </p>

    <div class="mt-14">
      <a href="/#contact" class="inline-flex">
        <button
          class="group relative overflow-hidden rounded-full px-12 py-4 text-sm font-semibold uppercase tracking-[0.18em]
          text-amber-100/90 transition-all duration-300
          border border-amber-200/35 bg-white/3 backdrop-blur-md
          hover:-translate-y-0.5 hover:border-amber-200/55 hover:bg-white/6
          hover:shadow-[0_20px_70px_rgba(251,191,36,0.16)]
          focus:outline-none focus-visible:ring-2 focus-visible:ring-amber-200/50 focus-visible:ring-offset-2 focus-visible:ring-offset-transparent"
        >
          <span class="absolute inset-0 opacity-0 transition-opacity duration-300 group-hover:opacity-100 bg-[radial-gradient(circle_at_30%_30%,rgba(255,220,160,0.22),transparent_55%)]"></span>
          <span class="relative z-10 flex items-center gap-3">
            Hai să vorbim
            <MoveRight className="h-4 w-4 transition-transform duration-300 group-hover:translate-x-1" />
          </span>
        </button>
      </a>
    </div>
  </div>
  
  <div class="pointer-events-none absolute bottom-0 left-0 right-0 h-[400px] bg-gradient-to-b from-transparent via-[#03060d]/60 to-[#03060d]"></div>
</section>

<style>
  @media (max-width: 768px) {
    section div[style*="background-image"] {
      background-attachment: scroll;
    }
  }
</style>