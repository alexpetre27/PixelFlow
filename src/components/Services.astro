---
import { Card } from "@/components/ui/card";
import { ui } from '@/i18n/ui';

const { lang = 'ro' } = Astro.props;
const t = ui[lang as keyof typeof ui];
---

<section id="services" class="relative w-full overflow-hidden bg-[#03060d] py-20 md:py-28">
  <div class="absolute inset-0 pointer-events-none"></div>

  <div class="relative z-10 mx-auto max-w-6xl px-6">
    <div class="mx-auto mb-14 max-w-2xl text-center">


      <h2 class="text-white font-semibold tracking-[-0.03em] leading-[1.08] text-3xl md:text-5xl">
        {t['services.title.1']}
        <span class="block mt-2 text-white/90">
          {t['services.title.2']}
          <span class="relative inline-block">
            <span class="text-amber-100/90">{t['services.title.3']}</span>
            <span class="absolute -bottom-2 left-0 h-px w-full bg-gradient-to-r from-transparent via-amber-200/60 to-transparent"></span>
          </span>
          .
        </span>
      </h2>

      <p class="mt-6 text-white/65 text-[16px] md:text-[18px] leading-relaxed">
        {t['services.desc']}
      </p>
    </div>

    <div class="grid grid-cols-1 gap-5 md:grid-cols-2 lg:grid-cols-4">
      <Card className="glass group relative overflow-hidden rounded-4xl p-7 shadow-soft transition-all duration-300 hover:-translate-y-[2px] hover:border-white/20 md:p-8">
        <div class="absolute inset-0 opacity-0 transition-opacity duration-300 group-hover:opacity-100 bg-[radial-gradient(circle_at_30%_25%,rgba(255,220,160,0.12),transparent_55%)]"></div>
        <div class="relative z-10">
          <div class="mb-5 inline-flex h-11 w-11 items-center justify-center rounded-2xl border border-white/10 bg-white/[0.03] text-amber-100/80 transition-all duration-300 group-hover:border-white/20 group-hover:bg-white/[0.06]">
            <svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="3" rx="2"/><path d="M3 9h18"/><path d="M9 21V9"/></svg>
          </div>
          <h3 class="text-[17px] font-bold tracking-tight text-white mb-2">{t['srv.1.title']}</h3>
          <p class="text-white/65 text-sm leading-relaxed">{t['srv.1.desc']}</p>
        </div>
      </Card>

      <Card className="glass group relative overflow-hidden rounded-4xl p-7 shadow-soft transition-all duration-300 hover:-translate-y-[2px] hover:border-white/20 md:p-8">
        <div class="absolute inset-0 opacity-0 transition-opacity duration-300 group-hover:opacity-100 bg-[radial-gradient(circle_at_30%_25%,rgba(255,220,160,0.12),transparent_55%)]"></div>
        <div class="relative z-10">
          <div class="mb-5 inline-flex h-11 w-11 items-center justify-center rounded-2xl border border-white/10 bg-white/[0.03] text-amber-100/80 transition-all duration-300 group-hover:border-white/20 group-hover:bg-white/[0.06]">
            <svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>
          </div>
          <h3 class="text-[17px] font-bold tracking-tight text-white mb-2">{t['srv.2.title']}</h3>
          <p class="text-white/65 text-sm leading-relaxed">{t['srv.2.desc']}</p>
        </div>
      </Card>

      <Card className="glass group relative overflow-hidden rounded-4xl p-7 shadow-soft transition-all duration-300 hover:-translate-y-[2px] hover:border-white/20 md:p-8">
        <div class="absolute inset-0 opacity-0 transition-opacity duration-300 group-hover:opacity-100 bg-[radial-gradient(circle_at_30%_25%,rgba(255,220,160,0.12),transparent_55%)]"></div>
        <div class="relative z-10">
          <div class="mb-5 inline-flex h-11 w-11 items-center justify-center rounded-2xl border border-white/10 bg-white/[0.03] text-amber-100/80 transition-all duration-300 group-hover:border-white/20 group-hover:bg-white/[0.06]">
            <svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2v20"/><path d="m17 5-5-3-5 3"/><path d="m17 19-5 3-5-3"/><path d="m2 12 5-3 5 3-5 3Z"/><path d="m12 12 5-3 5 3-5 3Z"/></svg>
          </div>
          <h3 class="text-[17px] font-bold tracking-tight text-white mb-2">{t['srv.3.title']}</h3>
          <p class="text-white/65 text-sm leading-relaxed">{t['srv.3.desc']}</p>
        </div>
      </Card>

      <Card className="glass group relative overflow-hidden rounded-4xl p-7 shadow-soft transition-all duration-300 hover:-translate-y-[2px] hover:border-white/20 md:p-8">
        <div class="absolute inset-0 opacity-0 transition-opacity duration-300 group-hover:opacity-100 bg-[radial-gradient(circle_at_30%_25%,rgba(255,220,160,0.12),transparent_55%)]"></div>
        <div class="relative z-10">
          <div class="mb-5 inline-flex h-11 w-11 items-center justify-center rounded-2xl border border-white/10 bg-white/[0.03] text-amber-100/80 transition-all duration-300 group-hover:border-white/20 group-hover:bg-white/[0.06]">
            <svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m16 16 3-8 3 8c-.87.65-1.92 1-3 1s-2.13-.35-3-1Z"/><path d="m2 16 3-8 3 8c-.87.65-1.92 1-3 1s-2.13-.35-3-1Z"/><path d="M7 21h10"/><path d="M12 3v18"/></svg>
          </div>
          <h3 class="text-[17px] font-bold tracking-tight text-white mb-2">{t['srv.4.title']}</h3>
          <p class="text-white/65 text-sm leading-relaxed">{t['srv.4.desc']}</p>
        </div>
      </Card>
    </div>
  </div>
</section>