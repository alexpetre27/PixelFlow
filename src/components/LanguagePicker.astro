---
const pathname = Astro.url.pathname;
const isEnglish = pathname.startsWith('/en');

const targetUrl = isEnglish ? '/' : '/en';

const label = isEnglish ? 'RO' : 'EN';
---

<a 
  href={targetUrl} 
  class="group relative inline-flex h-9 w-12 items-center justify-center overflow-hidden rounded-full border border-white/10 bg-white/3 text-[11px] font-bold uppercase tracking-widest text-zinc-300 backdrop-blur-md transition-all duration-300 hover:-translate-y-px hover:border-amber-200/35 hover:text-amber-100 hover:shadow-[0_4px_12px_rgba(251,191,36,0.12)]"
  aria-label="Schimbă limba / Change language"
>
  <span class="absolute inset-0 opacity-0 transition-opacity duration-300 group-hover:opacity-100 bg-[radial-gradient(circle_at_50%_50%,rgba(253,230,138,0.15),transparent_70%)]"></span>
  <span class="relative z-10">{label}</span>
</a>